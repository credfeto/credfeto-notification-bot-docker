#!/bin/sh

die() {
    if [ -t 2 ]; then
        printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    else
        printf '\n✗ %s\n' "$*" >&2
    fi
    exit 1
}

success() {
    if [ -t 1 ]; then
        printf '\n\033[32m✓\033[0m %s\n' "$*"
    else
        printf '\n✓ %s\n' "$*"
    fi
}

info() {
    if [ -t 1 ]; then
        printf '\n\033[32m→\033[0m %s\n' "$*"
    else
        printf '\n→ %s\n' "$*"
    fi
}

if [ "$(id -u)" -ne 0 ]; then
    exec sudo "$0" "$@"
fi

SERVICE_USER="notification-bot"
SERVICE_HOME="/var/lib/notification-bot"
SERVICE_UNIT="credfeto-notification-bot.service"

BASEDIR="$(dirname "$(readlink -f "$0")")"

cd "$BASEDIR" || die "Could not change to ${BASEDIR}"

command -v podman >/dev/null 2>&1 || die "podman is required"
id "$SERVICE_USER" >/dev/null 2>&1 || die "${SERVICE_USER} user does not exist - run ./install first"

SERVICE_UID="$(id -u "$SERVICE_USER")" || die "Failed to resolve UID for ${SERVICE_USER}"
SERVICE_RUNTIME_DIR="/run/user/${SERVICE_UID}"

info "Stopping systemd service"
systemctl stop "$SERVICE_UNIT" || die "Failed to stop ${SERVICE_UNIT}"

# podman-compose has no standalone "rm" subcommand (unlike docker compose) -
# "down" stops and removes in one step and is what it actually supports.
info "Stopping and removing containers"
runuser -u "$SERVICE_USER" -- env "HOME=${SERVICE_HOME}" "XDG_RUNTIME_DIR=${SERVICE_RUNTIME_DIR}" podman compose down || die "Failed to stop/remove containers"

info "Pruning podman system"
runuser -u "$SERVICE_USER" -- env "HOME=${SERVICE_HOME}" "XDG_RUNTIME_DIR=${SERVICE_RUNTIME_DIR}" podman system prune -f || die "Failed to prune podman system"

info "Running install"
"${BASEDIR}/install" || die "Install failed"

success "Reset complete"
