#!/bin/sh

die() {
    if [ -t 2 ]; then
        printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    else
        printf '\n✗ %s\n' "$*" >&2
    fi
    exit 1
}

success() {
    if [ -t 1 ]; then
        printf '\n\033[32m✓\033[0m %s\n' "$*"
    else
        printf '\n✓ %s\n' "$*"
    fi
}

info() {
    if [ -t 1 ]; then
        printf '\n\033[32m→\033[0m %s\n' "$*"
    else
        printf '\n→ %s\n' "$*"
    fi
}

BASEDIR="$(dirname "$(readlink -f "$0")")"

cd "$BASEDIR" || die "Could not change to ${BASEDIR}"

# The systemd unit's own XDG_RUNTIME_DIR=/run/user/%U is unreliable - on at
# least one real host %U resolved to the service manager's UID (0) rather
# than notification-bot's, pointing podman at the wrong (root-owned)
# runtime dir. Compute it from the actual running user instead, which is
# always correct regardless of specifier support/behaviour.
: "${XDG_RUNTIME_DIR:=/run/user/$(id -u)}"
export XDG_RUNTIME_DIR

command -v podman >/dev/null 2>&1 || die "podman is required"
podman compose version || die "podman compose is required"

info "Pulling images"
podman compose pull || die "Failed to pull images"

info "Starting containers"
podman compose up -d --remove-orphans || die "Failed to start containers"

# Every pull of a :latest tag leaves the previous image dangling
# (untagged) once containers are recreated to use the new one. Nothing
# else reclaims that disk space, and this runs on every update tick, so
# prune here - image prune only removes images no container references,
# and by this point any container using the old image has already been
# recreated above.
info "Pruning dangling images"
podman image prune -f || die "Failed to prune dangling images"

success "Containers up to date"
