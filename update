#! /bin/sh

die() {
    echo
    echo "$@"
    exit 1
}

BASEDIR="$(dirname "$(readlink -f "$0")")"
echo "Script Dir: $BASEDIR"

cd "$BASEDIR" || die "Could not change to $BASEDIR"

echo "Updating Repo"
git pull

[ -f "$BASEDIR/notification/appsettings-local.json" ] || die "Missing notification/appsettings-local.json"
[ -f "$BASEDIR/dispatcher/appsettings-local.json" ] || die "Missing dispatcher/appsettings-local.json"
[ -f "$BASEDIR/.env" ] || die "Missing .env file"
[ -f "$BASEDIR/proxy/credentials.json" ] || die "Missing proxy/credentials.json - copy proxy/credentials.example.json, fill in credentials, and run chmod 644"
command -v openssl >/dev/null 2>&1 || die "openssl is required"
chmod 644 "$BASEDIR/proxy/credentials.json"

CERT_DIR="$BASEDIR/certs"
CERT_FILE="$CERT_DIR/dispatcher.pfx"

echo "Ensuring dispatcher-data volume folder exists"
sudo mkdir -p /data/dispatcher
sudo docker volume create --driver local \
    --opt type=none \
    --opt o=bind \
    --opt device=/data/dispatcher \
    dispatcher-data 2>/dev/null || true

echo "Ensuring dispatcher certificate exists"
mkdir -p "$CERT_DIR" || die "Failed to create $CERT_DIR"

if [ ! -f "$CERT_FILE" ]; then
    TMP_KEY="$CERT_DIR/dispatcher.key"
    TMP_CRT="$CERT_DIR/dispatcher.crt"

    openssl req -x509 -nodes -newkey rsa:4096 \
        -keyout "$TMP_KEY" \
        -out "$TMP_CRT" \
        -days 3650 \
        -subj "/CN=dispatcher-bot" || die "Failed to generate self-signed certificate"

    openssl pkcs12 -export \
        -out "$CERT_FILE" \
        -inkey "$TMP_KEY" \
        -in "$TMP_CRT" \
        -passout pass: || die "Failed to generate $CERT_FILE"

    rm -f "$TMP_KEY" "$TMP_CRT"
    chmod 600 "$CERT_FILE"
fi

echo "Configuring firewall rules for TCP port 3000 (private networks only)"
# IPv4 private ranges
sudo firewall-cmd --permanent --add-rich-rule='rule family="ipv4" source address="10.0.0.0/8" port port="3000" protocol="tcp" accept'
sudo firewall-cmd --permanent --add-rich-rule='rule family="ipv4" source address="172.16.0.0/12" port port="3000" protocol="tcp" accept'
sudo firewall-cmd --permanent --add-rich-rule='rule family="ipv4" source address="192.168.0.0/16" port port="3000" protocol="tcp" accept'
# IPv6 private ranges (ULA fc00::/7 and link-local fe80::/10)
sudo firewall-cmd --permanent --add-rich-rule='rule family="ipv6" source address="fc00::/7" port port="3000" protocol="tcp" accept'
sudo firewall-cmd --permanent --add-rich-rule='rule family="ipv6" source address="fe80::/10" port port="3000" protocol="tcp" accept'
sudo firewall-cmd --reload

echo "Updating docker"
sudo docker compose pull && sudo docker compose up -d

echo "Done"
